  "keyFeatures": [
    "Adaptive AI analysis: automatically classifies films as 'entertainment' or 'deep/arthouse' and generates a tailored analysis",
    "Google Gemini 1.5 Flash integration for structured cinematic analysis in Spanish",
    "TMDB API v3 integration for film metadata, genres, keywords, and posters",
    "Analysis caching in MySQL to avoid redundant AI calls and reduce costs",
    "Three-tier user roles: Guest, Registered, and Admin with role-based access control",
    "JWT-based authentication with onboarding flow and cinephile level profiling",
    "Favorites system for registered users to save films",
    "Admin panel for managing films, regenerating AI analyses, and monitoring",
    "Search history tracking per user",
    "Two analysis modes: Entertainment (spoiler-free summary, epic moments, easter eggs) and Deep (symbolism, themes, cultural context, director analysis)"
  ],
  "publicApiSurface": [
    "POST /api/auth/register — Register a new user",
    "POST /api/auth/login — Authenticate and receive JWT",
    "GET /api/peliculas/buscar?q={query} — Search films via TMDB",
    "GET /api/peliculas/:id — Get film details",
    "POST /api/analisis/generar — Generate AI analysis for a film",
    "GET /api/analisis/:peliculaId — Retrieve stored analysis for a film",
    "GET /api/usuarios/perfil — Get current user profile",
    "POST /api/usuarios/favoritos — Add film to favorites",
    "DELETE /api/usuarios/favoritos/:peliculaId — Remove film from favorites",
    "GET /api/admin/peliculas — List all films (admin only)",
    "POST /api/admin/analisis/regenerar/:id — Force-regenerate AI analysis (admin only)"
  ]
}
